# ──────────────────────────────────────────────────
# Mockingbird Knowledge Web - Environment Variables
# Copy this file to .env.local and fill in real values.
# ──────────────────────────────────────────────────

# ── 站点基础 ──

# 站点绝对地址，用于 canonical / robots / sitemap / JSON-LD / OG
SITE_URL=https://zgnknowledge.online

# 站点品牌短名（用于导航、邮件品牌头等）
NEXT_PUBLIC_SITE_BRAND_NAME=知更鸟

# 站点完整名称（用于 SEO、页脚、结构化数据等）
NEXT_PUBLIC_SITE_NAME=知更鸟知识库

# 站点英文别名（用于 alternateName、页脚等）
NEXT_PUBLIC_SITE_ALTERNATE_NAME=Mockingbird Knowledge

# 备案信息
NEXT_PUBLIC_SITE_ICP_NUMBER=冀ICP备2024081438号
NEXT_PUBLIC_SITE_ICP_URL=https://beian.miit.gov.cn/

# ── 数据库 ──

# MySQL 连接地址（mysql2 格式）
MYSQL_URL=mysql://user:password@localhost:3306/mockingbird_knowledge

# ── 文章内容源 ──

# 本地文章源配置（JSON 数组）
# 当前生产 AI 文章源仓库：https://github.com/lanyijianke/web-article
# 本地先 clone：
#   git clone https://github.com/lanyijianke/web-article.git /Users/<you>/web-article
# 然后把 ARTICLE_LOCAL_SOURCES 配成下面这种形式：
#   [{"site":"ai","source":"web-article","rootPath":"/Users/<you>/web-article","manifestPath":"manifest.json"}]
ARTICLE_LOCAL_SOURCES=

# ── 提示词内容 ──

# 提示词图片/视频下载后的本地媒体目录
CONTENT_PROMPTS_MEDIA_DIR=./public/content/prompts/media

# 提示词同步的 GitHub 仓库源（JSON 数组，可选）
PROMPT_SYNC_REPOS=

# 提示词源配置目录（可选，有默认值）
# PROMPT_SOURCE_CONFIG_DIR=

# ── 管理接口鉴权 ──

# 管理接口鉴权 token（优先使用此变量）
KNOWLEDGE_ADMIN_TOKEN=

# 管理接口鉴权 token（兼容回退）
ADMIN_API_TOKEN=

# ── 调度器 ──

# 提示词同步 cron 表达式
JOB_PROMPT_SYNC_CRON=30 */1 * * * *

# 排行榜同步 cron 表达式
JOB_RANKING_SYNC_CRON=0 */2 * * *

# ── SEO ──

# 是否允许搜索引擎索引（true/false）
SEO_CAN_INDEX=false

# 是否屏蔽 Baidu 爬虫（true/false）
ROBOTS_BLOCK_BAIDU=false

# Sitemap 分片大小（可选，有默认值）
# SITEMAP_CHUNK_SIZE=1000

# ── 安全 ──

# 媒体下载最大字节数（SSRF/资源防护）
MEDIA_DOWNLOAD_MAX_BYTES=52428800

# ── 排行榜抓取（可选） ──

# Product Hunt API 密钥（热榜抓取用）
# PRODUCTHUNT_API_KEY=

# Product Hunt API Secret
# PRODUCTHUNT_API_SECRET=

# ── 邮件（可选） ──

# Resend API Key
# RESEND_API_KEY=

# 发件人名称
# RESEND_FROM_NAME=知更鸟

# 开发测试可用 onboarding@resend.dev；生产请改成已验证域名邮箱
# RESEND_FROM_EMAIL=onboarding@resend.dev

# ── SSO 客户端 ──

# Auth 服务地址
AUTH_SERVICE_URL=http://localhost:5050

# SSO 客户端 ID
AUTH_CLIENT_ID=mockingbird_website

# SSO 客户端密钥
AUTH_CLIENT_SECRET=

# SSO 回调地址
AUTH_CALLBACK_URL=http://localhost:5046/api/auth/callback

# SSO state cookie 名称
AUTH_STATE_COOKIE_NAME=auth_sso_state

# ── 日志 ──

# 日志级别：debug / info / warn / error
# LOG_LEVEL=info
