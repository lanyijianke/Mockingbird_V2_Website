# ──────────────────────────────────────────────────
# Mockingbird Knowledge Web - Environment Variables
# Copy this file to .env.local and fill in real values.
# ──────────────────────────────────────────────────

# ── 站点基础 ──

# 站点绝对地址，用于 canonical / robots / sitemap / JSON-LD / OG
SITE_URL=https://zgnknowledge.online

# 站点品牌短名（用于导航、邮件品牌头等）
NEXT_PUBLIC_SITE_BRAND_NAME=知更鸟 AI 知识库

# 站点完整名称（用于 SEO、页脚、结构化数据等）
NEXT_PUBLIC_SITE_NAME=知更鸟 AI 知识库

# 站点英文别名（用于 alternateName、页脚等）
NEXT_PUBLIC_SITE_ALTERNATE_NAME=Mockingbird Knowledge

# ── 数据库 ──

# MySQL 连接地址（mysql2 格式）
MYSQL_URL=mysql://user:password@localhost:3306/mockingbird_knowledge

# ── 文章内容源 ──

# R2 文章源配置（JSON 数组）
KNOWLEDGE_ARTICLE_R2_SOURCES=[{"site":"ai","source":"web-article","bucket":"knowledge-articles","prefix":"ai","manifestPath":"manifest.json","publicBaseUrl":"https://assets.zgnknowledge.online/ai"}]
KNOWLEDGE_R2_PUBLIC_ASSET_HOST=assets.zgnknowledge.online
KNOWLEDGE_R2_ACCOUNT_ID=
KNOWLEDGE_R2_ACCESS_KEY_ID=
KNOWLEDGE_R2_SECRET_ACCESS_KEY=

# ── 提示词内容 ──

# 提示词媒体使用临时文件处理，处理完成后直接上传 R2，不再保留本地持久目录。
KNOWLEDGE_PROMPT_MEDIA_R2_BUCKET=knowledge-articles
KNOWLEDGE_PROMPT_MEDIA_R2_PREFIX=prompts/media
KNOWLEDGE_PROMPT_MEDIA_R2_PUBLIC_BASE_URL=https://assets.zgnknowledge.online/prompts/media

# 提示词同步的 GitHub 仓库源（JSON 数组，可选；内置默认读取 content-sources/prompts/*.json）
# 如需用环境变量覆盖，需要显式提供 rawUrlTemplate / repoUrlTemplate。
# 示例：
# [{"owner":"ExampleOrg","repo":"example-prompts","branch":"main","file":"README.md","rawUrlTemplate":"https://raw.example.com/{owner}/{repo}/{branch}/{file}","repoUrlTemplate":"https://repo.example.com/{owner}/{repo}","category":"multimodal-prompts"}]
PROMPT_SYNC_REPOS=

# 提示词源配置目录（可选，有默认值）
# PROMPT_SOURCE_CONFIG_DIR=

# ── 管理接口鉴权 ──

# 管理接口鉴权 token（优先使用此变量）
KNOWLEDGE_ADMIN_TOKEN=

# 管理接口鉴权 token（兼容回退）
ADMIN_API_TOKEN=

# 内容发布/同步后统一重验证接口复用上述管理 token：
# POST /api/revalidate/content

# ── 调度器 ──

# 提示词同步 cron 表达式（默认每 2 小时）
JOB_PROMPT_SYNC_CRON=30 0 */2 * * *

# 排行榜同步 cron 表达式
JOB_RANKING_SYNC_CRON=0 */2 * * *

# ── SEO ──

# 是否允许搜索引擎索引（true/false）
SEO_CAN_INDEX=false

# 是否屏蔽 Baidu 爬虫（true/false）
ROBOTS_BLOCK_BAIDU=false

# Sitemap 分片大小（可选，有默认值）
# SITEMAP_CHUNK_SIZE=1000

# ── 安全 ──

# 媒体下载最大字节数（SSRF/资源防护）
MEDIA_DOWNLOAD_MAX_BYTES=52428800

# ── 排行榜抓取（可选） ──

# Product Hunt API 密钥（热榜抓取用）
# PRODUCTHUNT_API_KEY=

# Product Hunt API Secret
# PRODUCTHUNT_API_SECRET=

# ── 邮件（可选） ──

# Resend API Key
# RESEND_API_KEY=

# 发件人名称
# RESEND_FROM_NAME=知更鸟

# 开发测试可用 onboarding@resend.dev；生产请改成已验证域名邮箱
# RESEND_FROM_EMAIL=onboarding@resend.dev

# ── 日志 ──

# 日志级别：debug / info / warn / error
# LOG_LEVEL=info
