  "style_rules": {
    "keep_english": [
      "品牌名/产品名（Apple、Google、Tesla、OpenAI、Anthropic 等）",
      "人名（首次出现时可在括号中加中文译名）",
      "公司名/机构名（Y Combinator、Sequoia、a16z 等）",
      "技术协议/标准（HTTP、TCP/IP、REST、GraphQL 等）",
      "编程语言（Python、JavaScript、Rust 等）",
      "缩写术语（API、SDK、CLI、SaaS、LLM、AGI 等）",
      "已在中文社区广泛接受的英文术语（commit、PR、repo、token、prompt 等）"
    ],
    "always_translate": [
      "普通名词概念（framework → 框架，startup → 创业公司）",
      "动词性术语（deploy → 部署，refactor → 重构）",
      "描述性短语（best practice → 最佳实践，pain point → 痛点）",
      "比喻性表达（moat → 护城河，unicorn → 独角兽）"
    ],
    "punctuation": {
      "rule": "中文文本使用中文标点，英文术语/代码周围使用英文标点",
      "examples": [
        "Y Combinator 的创始人",
        "使用 Python、JavaScript 和 Rust",
        "调用 API 获取数据",
        "这是一个 MVP，用来验证 PMF"
      ]
    },
    "mixed_sentence": {
      "rule": "中英混排时，英文前后各空半角空格",
      "examples": [
        "这是一个很好的 MVP 模式",
        "他在 Y Combinator 工作了三年",
        "使用了 LLM 来做翻译"
      ]
    },
    "first_mention": {
      "rule": "专业术语首次出现时可加括号注释英文原文",
      "examples": [
        "强化学习（Reinforcement Learning）",
